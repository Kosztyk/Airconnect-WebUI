<?xml version="1.0"?>
<airupnp>
  <common>
    <enabled>1</enabled>
    <name>%s+</name>
    <codec>flac</codec>
    <metadata>1</metadata>
    <flush>1</flush>
    <drift>0</drift>
    <http_length>-1</http_length>
    <upnp_max>1</upnp_max>
    <latency>1000:2000</latency>
  </common>
  <main_log>info</main_log>
  <util_log>warn</util_log>
  <upnp_log>info</upnp_log>
  <raop_log>info</raop_log>
  <log_limit>-1</log_limit>
  <max_players>32</max_players>
  <binding>?</binding>
  <ports>0:0</ports>
</airupnp>
