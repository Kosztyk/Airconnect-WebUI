<?xml version="1.0"?>
<aircast>
  <common>
    <enabled>1</enabled>
    <name>%s+</name>
    <codec>flac</codec>
    <metadata>1</metadata>
    <flush>1</flush>
    <drift>0</drift>
    <media_volume>0.5</media_volume>
  </common>
  <main_log>info</main_log>
  <util_log>warn</util_log>
  <cast_log>info</cast_log>
  <raop_log>info</raop_log>
  <log_limit>-1</log_limit>
  <max_players>32</max_players>
  <binding>?</binding>
  <ports>0:0</ports>
</aircast>
